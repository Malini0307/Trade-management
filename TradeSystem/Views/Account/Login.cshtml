@{
    ViewData["Title"] = "Login";
    var role = (string?)ViewBag.Role ?? "";
    // Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-5">
    <h2 class="text-center mb-4">Login @if(!string.IsNullOrEmpty(role)){
    <text>as <strong>@role</strong></text>
        }
</h2>

    @if (TempData["Msg"] != null)
    {
        <div class="alert alert-success w-50 mx-auto text-center">@TempData["Msg"]</div>
    }

    <form method="post" class="w-50 mx-auto card p-4 shadow-sm border-0">
        <input type="hidden" name="role" value="@role" />
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" required />
        </div>
        @if (string.IsNullOrEmpty(role))
        {
            <div class="mb-3">
                <label class="form-label">Role</label>
                <select name="role" class="form-select" required>
                    <option value="">Select role</option>
                    <option value="Admin">Admin</option>
                    <option value="User">User</option>
                </select>
            </div>
        }
        @Html.AntiForgeryToken()
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@Html.Raw(ViewBag.Error)</div>
        }
        <button type="submit" class="btn btn-primary w-100">Login</button>
        <div class="text-center mt-3">
            <a href="/Account/Register?role=@role">Don’t have an account? Register</a>
        </div>
    </form>
</div>
