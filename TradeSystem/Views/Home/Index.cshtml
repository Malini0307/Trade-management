@{
    ViewData["Title"] = "Home";
}
<div class="container my-5">
    <h1 class="text-center mb-2">Welcome to Trade Finance Management System</h1>
    <p class="text-center lead mb-5">Please select your role to continue:</p>

    <div class="row justify-content-center g-4">
        <!-- Admin Card -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center h-100 role-card">
                <div class="card-body d-flex flex-column justify-content-center align-items-center p-4">
                    <i class="bi bi-shield-lock fs-1 text-warning"></i>
                    <h3 class="card-title my-3">Admin</h3>
                    <p class="card-text">Manage users, LCs, guarantees, risk & compliance.</p>
                    <div class="d-grid gap-2 w-100 mt-3">
                        <a href="/Account/Login?role=Admin" class="btn btn-primary">Login</a>
                        <a href="/Account/Register?role=Admin" class="btn btn-outline-primary">Register</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Card -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center h-100 role-card">
                <div class="card-body d-flex flex-column justify-content-center align-items-center p-4">
                    <i class="bi bi-person-circle fs-1 text-success"></i>
                    <h3 class="card-title my-3">User</h3>
                    <p class="card-text">Submit LCs, request guarantees, upload documents.</p>
                    <div class="d-grid gap-2 w-100 mt-3">
                        <a href="/Account/Login?role=User" class="btn btn-success">Login</a>
                        <a href="/Account/Register?role=User" class="btn btn-outline-success">Register</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
