@{
    ViewData["Title"] = "Risk Assessment";
}
<div class="container mt-4">
  <h2>Collective Risk Assessment</h2>
  <p class="text-muted">Enter an LC Id to assess risk collectively across its LC, related BGs, and linked Trade Documents.</p>

  <div class="row g-3 my-3">
    <div class="col-md-6">
      <label class="form-label">LC Id</label>
      <div class="input-group">
        <input type="number" id="lcId" class="form-control" placeholder="LC Id">
        <button class="btn btn-primary" onclick="analyzeCollective()">Analyze</button>
      </div>
    </div>
  </div>

  <div id="result" class="mt-4"></div>
</div>

@section Scripts {
<script>
async function analyzeCollective() {
  const id = document.getElementById('lcId').value;
  if (!id) return;
  const res = await fetch(`/RiskAssessment/analyze/collective/${id}`, { method: 'POST' });
  await showResult(res);
}

async function showResult(res) {
  const el = document.getElementById('result');
  if (!res.ok) {
    const txt = await res.text();
    el.innerHTML = `<div class="alert alert-danger">Error: ${txt}</div>`;
    return;
  }
  const data = await res.json();
  const factors = JSON.parse(data.riskFactors ?? "{}");
  el.innerHTML = `
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title">Risk Score: <strong>${(data.riskScore ?? 0).toFixed(2)}</strong> / 100</h5>
        <p class="mb-1">Reference: ${data.transactionReference ?? ''}</p>
        <p class="mb-1">LC Id: ${data.lcId ?? '-'}</p>
        <h6 class="mt-3">Factors</h6>
        <pre class="bg-light p-3 border rounded">${JSON.stringify(factors, null, 2)}</pre>
      </div>
    </div>`;
}
</script>
}