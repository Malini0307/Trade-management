@model TradeSystem.Models.TradeDocument
@{
    ViewData["Title"] = "Trade Document Details";
}
<div class="container mt-4">
    <h2>Document Details</h2>
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Reference</dt>
                <dd class="col-sm-9">@Model.ReferenceNumber</dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@Model.DocumentType</dd>

                <dt class="col-sm-3">Uploaded By</dt>
                <dd class="col-sm-9">@Model.UploadedBy</dd>

                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@Model.UploadDate.ToString("yyyy-MM-dd HH:mm")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Linked</dt>
                <dd class="col-sm-9">
                    @if (Model.LcId.HasValue)
                    {
                        <span>LC #@Model.LcId</span>
                    }
                    @if (Model.GuaranteeId.HasValue)
                    {
                        <span class="ms-2">BG #@Model.GuaranteeId</span>
                    }
                    @if (!Model.LcId.HasValue && !Model.GuaranteeId.HasValue)
                    {
                        <span>-</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back</a>
        @if (User.IsInRole("User"))
        {
            <a asp-action="Edit" asp-route-id="@Model.DocumentId" class="btn btn-primary ms-2">Edit</a>
        }
    </div>
</div>
