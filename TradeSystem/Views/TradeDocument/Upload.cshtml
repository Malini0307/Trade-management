@model TradeSystem.Models.TradeDocument
@{
    ViewData["Title"] = "Upload Trade Document";
    var docTypes = (SelectList)ViewBag.DocTypes;
    var lcs = (SelectList)ViewBag.LCs;
    var bgs = (SelectList)ViewBag.BGs;
}
<div class="container mt-4">
    <h2 class="mb-3">Upload Trade Document</h2>
    <form asp-action="Upload" method="post" class="card p-4 shadow-sm border-0">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Reference Number</label>
                <input asp-for="ReferenceNumber" class="form-control" readonly />
                <span class="form-text">Auto-generated and unique</span>
            </div>
            <div class="col-md-4">
                <label class="form-label">Document Type</label>
                <select asp-for="DocumentType" class="form-select" asp-items="docTypes"></select>
                <span asp-validation-for="DocumentType" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select asp-for="Status" class="form-select">
                    <option value="0">Active</option>
                    <option value="1">Archived</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
        </div>

        <hr />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Link to Letter of Credit (optional)</label>
                <select asp-for="LcId" class="form-select" asp-items="lcs">
                    <option value="">-- None --</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Link to Bank Guarantee (optional)</label>
                <select asp-for="GuaranteeId" class="form-select" asp-items="bgs">
                    <option value="">-- None --</option>
                </select>
            </div>
        </div>



        <div class="mt-4 d-flex justify-content-end">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-success">Upload</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
