@{
    ViewData["Title"] = "User Dashboard";
}
<div class="container">
    <h2 class="mb-4">Welcome, @ViewBag.UserName</h2>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body"><h5 class="card-title">Letter of Credit</h5><p class="card-text">Submit & track LC requests.</p>
                    <a href="@Url.Action("Index", "LetterOfCredit")" class="btn btn-primary">Go</a>
                    </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body"><h5 class="card-title">Bank Guarantee</h5><p class="card-text">Request & track guarantees.</p>
                    <a href="@Url.Action("Index", "BankGuarantee")" class="btn btn-primary">Go</a>
                    </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body"><h5 class="card-title">Trade Documents</h5><p class="card-text">Upload & manage documents linked to LC/BG.</p><a asp-controller="TradeDocument" asp-action="Index" class="btn btn-primary">Go</a></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body"><h5 class="card-title">Risk Scores</h5><p class="card-text">View transaction risk.</p><a href="#" class="btn btn-primary">Go</a></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body"><h5 class="card-title">Compliance</h5><p class="card-text">Check compliance status.</p><a href="#" class="btn btn-primary">Go</a></div>
            </div>
        </div>
    </div>
</div>
