@{
    ViewData["Title"] = "User Dashboard";
}
<div class="container">
  <h2 class="mb-4">Welcome, @ViewBag.UserName</h2>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <h5 class="card-title">Letters of Credit</h5>
          <p class="card-text">View and manage your LC (where permitted).</p>
          <a asp-controller="LetterOfCredit" asp-action="Index" class="btn btn-primary">Open</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <h5 class="card-title">Bank Guarantees</h5>
          <p class="card-text">Request and track BG.</p>
          <a asp-controller="BankGuarantee" asp-action="Index" class="btn btn-primary">Open</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <h5 class="card-title">Trade Documents</h5>
          <p class="card-text">Upload and edit trade documents.</p>
          <a asp-controller="TradeDocument" asp-action="Index" class="btn btn-primary">Open</a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <h5 class="card-title">Risk Assessment</h5>
          <p class="card-text">Collective risk scoring by LC.</p>
          <a asp-controller="RiskAssessment" asp-action="Index" class="btn btn-primary">Open</a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <h5 class="card-title">Compliance</h5>
          <p class="card-text">View compliance reports (read-only).</p>
          <a asp-controller="Compliance" asp-action="Index" class="btn btn-outline-primary">View Reports</a>
        </div>
      </div>
    </div>
  </div>
</div>

@section Footer {
    @await Html.PartialAsync("_Footer")
}
